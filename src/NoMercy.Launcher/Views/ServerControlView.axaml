<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NoMercy.Launcher.ViewModels"
        x:Class="NoMercy.Launcher.Views.ServerControlView"
        x:DataType="vm:ServerControlViewModel">

    <DockPanel Margin="16">
        <!-- Title -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Server Control"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#e0e0e0"
                   Margin="0,0,0,16" />

        <!-- Action status (bottom) -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding ActionStatus}"
                   Foreground="#999999"
                   FontSize="12"
                   Margin="0,8,0,0"
                   HorizontalAlignment="Center" />

        <!-- Control buttons (bottom) -->
        <Border DockPanel.Dock="Bottom"
                Background="#16161e"
                BorderBrush="#2a2a3a"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,16,0,0">
            <WrapPanel HorizontalAlignment="Center"
                       Orientation="Horizontal">
                <Button x:Name="OpenAppButton"
                        Content="Open App"
                        MinWidth="120"
                        HorizontalContentAlignment="Center"
                        IsEnabled="{Binding IsServerRunning}"
                        Click="OnOpenAppClick"
                        Background="#8f00fc"
                        Foreground="White"
                        Margin="4" />

                <Button x:Name="StartButton"
                        Content="Start Server"
                        MinWidth="120"
                        HorizontalContentAlignment="Center"
                        IsEnabled="{Binding IsServerStopped}"
                        Click="OnStartClick"
                        Background="#16A34A"
                        Foreground="White"
                        Margin="4" />

                <Button x:Name="StopButton"
                        Content="Stop Server"
                        MinWidth="120"
                        HorizontalContentAlignment="Center"
                        IsEnabled="{Binding IsServerRunning}"
                        Click="OnStopClick"
                        Background="#DC2626"
                        Foreground="White"
                        Margin="4" />

                <Button x:Name="RestartButton"
                        Content="Restart Server"
                        MinWidth="120"
                        HorizontalContentAlignment="Center"
                        IsEnabled="{Binding IsServerRunning}"
                        Click="OnRestartClick"
                        Background="#705BAD"
                        Foreground="White"
                        Margin="4" />

                <Button x:Name="RefreshButton"
                        Content="Refresh"
                        MinWidth="120"
                        HorizontalContentAlignment="Center"
                        Click="OnRefreshClick"
                        Margin="4" />
            </WrapPanel>
        </Border>

        <!-- Fill area: status + toggles -->
        <StackPanel Spacing="16">
            <!-- Status indicator -->
            <Border Background="#16161e"
                    BorderBrush="#2a2a3a"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">
                <Grid ColumnDefinitions="Auto,Auto,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                    <!-- Status row -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Status:"
                               Foreground="#999999"
                               FontSize="13"
                               Margin="0,0,12,6"
                               VerticalAlignment="Center" />
                    <Ellipse Grid.Row="0" Grid.Column="1"
                             Width="10" Height="10"
                             Margin="0,0,8,6"
                             VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding StatusColor}" />
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="{Binding ServerStatus}"
                               Foreground="#e0e0e0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"
                               VerticalAlignment="Center" />

                    <!-- Server Name -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Server:"
                               Foreground="#999999"
                               FontSize="13"
                               Margin="0,0,12,6" />
                    <TextBlock Grid.Row="1" Grid.Column="2"
                               Text="{Binding ServerName}"
                               Foreground="#e0e0e0"
                               FontSize="13"
                               Margin="0,0,0,6" />

                    <!-- Version -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Version:"
                               Foreground="#999999"
                               FontSize="13"
                               Margin="0,0,12,6" />
                    <TextBlock Grid.Row="2" Grid.Column="2"
                               Text="{Binding Version}"
                               Foreground="#e0e0e0"
                               FontSize="13"
                               Margin="0,0,0,6" />

                    <!-- Platform -->
                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="Platform:"
                               Foreground="#999999"
                               FontSize="13"
                               Margin="0,0,12,6" />
                    <TextBlock Grid.Row="3" Grid.Column="2"
                               Text="{Binding Platform}"
                               Foreground="#e0e0e0"
                               FontSize="13"
                               Margin="0,0,0,6" />

                    <!-- Uptime -->
                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="Uptime:"
                               Foreground="#999999"
                               FontSize="13"
                               Margin="0,0,12,0" />
                    <TextBlock Grid.Row="4" Grid.Column="2"
                               Text="{Binding Uptime}"
                               Foreground="#e0e0e0"
                               FontSize="13" />
                </Grid>
            </Border>

            <!-- Update banner -->
            <Border IsVisible="{Binding UpdateAvailable}"
                    Background="#1a1530"
                    BorderBrush="#3a2a5a"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding LatestVersion, StringFormat='Update available: v{0}'}"
                               Foreground="#CBAFFF"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="Restart to update"
                            Click="OnApplyUpdate"
                            Background="#8f00fc"
                            Foreground="White"
                            Padding="12,6" />
                </Grid>
            </Border>

            <!-- Auto-start toggle -->
            <Border Background="#16161e"
                    BorderBrush="#2a2a3a"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="Start on boot"
                               Foreground="#e0e0e0"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <CheckBox x:Name="AutoStartCheckBox"
                              Grid.Column="1"
                              IsChecked="{Binding AutoStartEnabled}"
                              Click="OnAutoStartToggle"
                              VerticalAlignment="Center" />
                </Grid>
            </Border>
        </StackPanel>

    </DockPanel>
</UserControl>
